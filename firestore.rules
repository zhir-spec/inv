rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, brokerId, referralCode, level, stats, createdAt
    //
    // Collection: brokers
    // Fields: id, name, domain, branding, stats, createdAt
    //
    // Collection: clicks
    // Fields: affiliateId, referralCode, timestamp, userAgent, brokerId
    //
    // Collection: referrals
    // Fields: affiliateId, referredUserId, status, timestamp, value, brokerId
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin') ||
          (request.auth.token.email == "zhir.investmentspot@gmail.com")
        );
    }

    function isBrokerAdmin(brokerId) {
      return isAuthenticated() && 
        (getUserData().role == 'broker_admin' && getUserData().brokerId == brokerId) || isSuperAdmin();
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.email is string &&
             data.role in ['super_admin', 'broker_admin', 'affiliate'];
    }

    function isValidBroker(data) {
      return data.keys().hasAll(['id', 'name', 'domain', 'branding']) &&
             data.id is string && data.name is string && data.domain is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated(); 
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'affiliate' || request.auth.token.email == "zhir.investmentspot@gmail.com");
      allow update: if isAuthenticated() && (isOwner(userId) || isSuperAdmin()) && 
                    isValidUser(request.resource.data) &&
                    (isSuperAdmin() || request.resource.data.role == resource.data.role);
    }

    match /brokers/{brokerId} {
      allow read: if true; // Publicly readable for branding
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || isBrokerAdmin(brokerId);
    }

    match /clicks/{clickId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.affiliateId) || isBrokerAdmin(resource.data.brokerId));
      allow create: if true; // Publicly writable for tracking
      allow update, delete: if isSuperAdmin();
    }

    match /referrals/{referralId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.affiliateId) || isBrokerAdmin(resource.data.brokerId));
      allow create: if isSuperAdmin() || isBrokerAdmin(request.resource.data.brokerId);
      allow update, delete: if isSuperAdmin();
    }

    match /demo_requests/{requestId} {
      allow create: if true; // Publicly writable for demo requests
      allow read, update, delete: if isSuperAdmin();
    }
  }
}
