{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile for super admins, broker admins, and affiliates",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile picture URL" },
        "role": { "type": "string", "enum": ["super_admin", "broker_admin", "affiliate"], "description": "User role" },
        "brokerId": { "type": "string", "description": "ID of the broker this user belongs to (null for super_admin)" },
        "referralCode": { "type": "string", "description": "Unique affiliate referral code" },
        "level": { "type": "string", "enum": ["Bronze", "Silver", "Gold"], "description": "Affiliate level" },
        "stats": {
          "type": "object",
          "properties": {
            "clicks": { "type": "number" },
            "signups": { "type": "number" },
            "conversions": { "type": "number" },
            "earnings": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "brokers": {
      "title": "Broker",
      "description": "Broker entity for multi-tenant SaaS",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Broker unique ID" },
        "name": { "type": "string", "description": "Broker name" },
        "domain": { "type": "string", "description": "Broker subdomain/slug" },
        "branding": {
          "type": "object",
          "properties": {
            "primaryColor": { "type": "string" },
            "secondaryColor": { "type": "string" },
            "accentColor": { "type": "string" },
            "logoUrl": { "type": "string" },
            "companyName": { "type": "string" },
            "heroTitle": { "type": "string" },
            "heroSubtitle": { "type": "string" }
          }
        },
        "stats": {
          "type": "object",
          "properties": {
            "totalAffiliates": { "type": "number" },
            "totalClicks": { "type": "number" },
            "totalSignups": { "type": "number" },
            "totalRevenue": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "domain", "branding"]
    },
    "clicks": {
      "title": "Click",
      "description": "Tracking for referral link clicks",
      "type": "object",
      "properties": {
        "affiliateId": { "type": "string", "description": "UID of the affiliate" },
        "referralCode": { "type": "string", "description": "Referral code used" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the click occurred" },
        "userAgent": { "type": "string", "description": "Browser user agent" },
        "ip": { "type": "string", "description": "IP address (anonymized or masked)" }
      },
      "required": ["affiliateId", "referralCode", "timestamp"]
    },
    "referrals": {
      "title": "Referral",
      "description": "Tracking for referred signups",
      "type": "object",
      "properties": {
        "affiliateId": { "type": "string", "description": "UID of the affiliate" },
        "referredUserId": { "type": "string", "description": "UID of the referred user" },
        "status": { "type": "string", "enum": ["signup", "conversion"], "description": "Referral status" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the referral occurred" },
        "value": { "type": "number", "description": "Monetary value of conversion" }
      },
      "required": ["affiliateId", "referredUserId", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "users" },
      "description": "User profiles and affiliate stats"
    },
    "/brokers/{brokerId}": {
      "schema": { "$ref": "brokers" },
      "description": "Broker configurations and branding"
    },
    "/clicks/{clickId}": {
      "schema": { "$ref": "clicks" },
      "description": "Referral click tracking logs"
    },
    "/referrals/{referralId}": {
      "schema": { "$ref": "referrals" },
      "description": "Referral signup and conversion tracking"
    }
  }
}
